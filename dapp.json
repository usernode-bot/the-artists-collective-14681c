{
  "name": "The Artists' Collective",
  "secrets": [
    {
      "key": "NODE_RPC_URL",
      "description": "Base URL of the Usernode block-explorer / node RPC. The /explorer-api proxy forwards getTransactions read-back here. Platform-managed in-network; this default is only used for standalone deploys.",
      "required": false,
      "private": false,
      "default": "http://host.docker.internal:3001"
    },
    {
      "key": "CHAIN_ID",
      "description": "Chain id segment the explorer expects in its transactions path (POST /<chain_id>/transactions). The /explorer-api proxy inserts it between NODE_RPC_URL and the sub-path. Leave unset to forward without a chain segment.",
      "required": false,
      "private": false
    },
    {
      "key": "WEB_ACCESS_KEY",
      "description": "Bearer token for the gallery website's POST /api/web-access endpoint (mints desktop sign-in codes for artists). Server-side only — never exposed to the browser. Set in App Settings → Secrets after the build.",
      "required": false,
      "private": true
    }
  ],
  "visibility": {
    "build": "private",
    "view": "public"
  },
  "tests": [
    {
      "name": "Studio gate renders",
      "path": "/",
      "expectSelector": "#view-gate"
    },
    {
      "name": "Studio dashboard renders",
      "path": "/?demo=1",
      "expectSelector": "#view-dash"
    },
    {
      "name": "Forum tab renders",
      "path": "/?demo=1",
      "expectSelector": "#tab-forum"
    },
    {
      "name": "Desktop access button renders",
      "path": "/?demo=1",
      "expectSelector": "#web-access-btn"
    },
    {
      "name": "Profile avatar renders",
      "path": "/?demo=1",
      "expectSelector": "#avatar"
    },
    {
      "name": "Change profile picture button renders",
      "path": "/?demo=1",
      "expectSelector": "#avatar-change-btn"
    },
    {
      "name": "Messages tab renders",
      "path": "/?demo=1",
      "expectSelector": "#tab-messages"
    },
    {
      "name": "Messages view renders",
      "path": "/?demo=1",
      "expectSelector": "#view-messages"
    },
    {
      "name": "Welcome panel renders",
      "path": "/?demo=welcome",
      "expectSelector": "#view-welcome"
    },
    {
      "name": "Fee Split outcome badge renders",
      "path": "/?demo=1",
      "expectSelector": ".proposal-outcome"
    }
  ]
}
